<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports 
    http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
    name="GoodsReceiptDetail"
    pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <!-- PARAMETERS -->
    <parameter name="receiptCode" class="java.lang.String"/>
    <parameter name="purchaseOrderCode" class="java.lang.String"/>
    <parameter name="receiptDate" class="java.lang.String"/>
    <parameter name="receivedBy" class="java.lang.String"/>
    <parameter name="note" class="java.lang.String"/>

    <!-- FIELDS -->
    <field name="productName" class="java.lang.String"/>
    <field name="quantity" class="java.lang.Integer"/>

    <!-- ================= HEADER ================= -->
    <title>
        <band height="80">
            <staticText>
                <reportElement x="0" y="0" width="555" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="22" isBold="true"/>
                </textElement>
                <text><![CDATA[GOODS RECEIPT DETAIL]]></text>
            </staticText>
        </band>
    </title>

    <!-- ================= GR INFO ================= -->
    <pageHeader>
        <band height="100">
            <staticText>
                <reportElement x="0" y="0" width="120" height="20"/>
                <text><![CDATA[Receipt Code :]]></text>
            </staticText>
            <textField>
                <reportElement x="120" y="0" width="200" height="20"/>
                <textFieldExpression><![CDATA[$P{receiptCode}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="20" width="120" height="20"/>
                <text><![CDATA[PO Code :]]></text>
            </staticText>
            <textField>
                <reportElement x="120" y="20" width="200" height="20"/>
                <textFieldExpression><![CDATA[$P{purchaseOrderCode}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="40" width="120" height="20"/>
                <text><![CDATA[Receipt Date :]]></text>
            </staticText>
            <textField>
                <reportElement x="120" y="40" width="200" height="20"/>
                <textFieldExpression><![CDATA[$P{receiptDate}]]></textFieldExpression>
            </textField>
            
            <staticText>
                <reportElement x="0" y="60" width="120" height="20"/>
                <text><![CDATA[Received By :]]></text>
            </staticText>
            <textField>
                <reportElement x="120" y="60" width="200" height="20"/>
                <textFieldExpression><![CDATA[$P{receivedBy}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="80" width="120" height="20"/>
                <text><![CDATA[Notes :]]></text>
            </staticText>
            <textField>
                <reportElement x="120" y="80" width="300" height="20"/>
                <textFieldExpression><![CDATA[$P{note}]]></textFieldExpression>
            </textField>

        </band>
    </pageHeader>

    <!-- ================= TABLE HEADER ================= -->
    <columnHeader>
        <band height="30">
            <staticText>
                <reportElement x="0" y="0" width="400" height="30"/>
                <box><pen lineWidth="1.0"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Product Name]]></text>
            </staticText>

            <staticText>
                <reportElement x="400" y="0" width="155" height="30"/>
                <box><pen lineWidth="1.0"/></box>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true"/>
                </textElement>
                <text><![CDATA[Qty Received]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- ================= DETAIL ================= -->
    <detail>
        <band height="25">
            <textField textAdjust="StretchHeight">
                <reportElement x="0" y="0" width="400" height="25"/>
                <box padding="3"><pen lineWidth="0.5"/></box>
                <textFieldExpression><![CDATA[$F{productName}]]></textFieldExpression>
            </textField>

            <textField>
                <reportElement x="400" y="0" width="155" height="25"/>
                <box padding="3"><pen lineWidth="0.5"/></box>
                <textElement textAlignment="Center"/>
                <textFieldExpression><![CDATA[$F{quantity}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <summary>
        <band height="80">
            <staticText>
                <reportElement x="100" y="50" width="150" height="20"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[Prepared By]]></text>
            </staticText>

            <staticText>
                <reportElement x="300" y="50" width="150" height="20"/>
                <textElement textAlignment="Center"/>
                <text><![CDATA[Approved By]]></text>
            </staticText>
        </band>
    </summary>

</jasperReport>
