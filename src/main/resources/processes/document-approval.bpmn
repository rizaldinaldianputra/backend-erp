<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_DocumentApproval" targetNamespace="http://bpmn.io/schema/bpmn" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:process id="document-approval" name="Document Approval" isExecutable="true" camunda:historyTimeToLive="90">
    <bpmn:startEvent id="StartEvent_1" name="Document Submitted">
      <bpmn:outgoing>Flow_to_pending</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_SetPending" name="Set Pending Approval" camunda:delegateExpression="${setStatusPendingDelegate}">
      <bpmn:incoming>Flow_to_pending</bpmn:incoming>
      <bpmn:outgoing>Flow_to_review</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ReviewDocument" name="Review Document" camunda:assignee="${supervisorUsername}">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="approved" label="Approved?" type="boolean" defaultValue="true" />
          <camunda:formField id="comment" label="Comment" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_to_review</bpmn:incoming>
      <bpmn:outgoing>Flow_to_gateway</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Decision" name="Approved?">
      <bpmn:incoming>Flow_to_gateway</bpmn:incoming>
      <bpmn:outgoing>Flow_approved</bpmn:outgoing>
      <bpmn:outgoing>Flow_rejected</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_ApplyApproval" name="Apply Approval" camunda:delegateExpression="${approveDocumentDelegate}">
      <bpmn:incoming>Flow_approved</bpmn:incoming>
      <bpmn:outgoing>Flow_to_end_approved</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_ApplyRejection" name="Apply Rejection" camunda:delegateExpression="${rejectDocumentDelegate}">
      <bpmn:incoming>Flow_rejected</bpmn:incoming>
      <bpmn:outgoing>Flow_to_end_rejected</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Approved" name="Approved">
      <bpmn:incoming>Flow_to_end_approved</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Rejected" name="Rejected">
      <bpmn:incoming>Flow_to_end_rejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_to_pending" sourceRef="StartEvent_1" targetRef="Task_SetPending" />
    <bpmn:sequenceFlow id="Flow_to_review" sourceRef="Task_SetPending" targetRef="Task_ReviewDocument" />
    <bpmn:sequenceFlow id="Flow_to_gateway" sourceRef="Task_ReviewDocument" targetRef="Gateway_Decision" />
    <bpmn:sequenceFlow id="Flow_approved" name="Approved" sourceRef="Gateway_Decision" targetRef="Task_ApplyApproval">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_rejected" name="Rejected" sourceRef="Gateway_Decision" targetRef="Task_ApplyRejection">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${approved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_to_end_approved" sourceRef="Task_ApplyApproval" targetRef="EndEvent_Approved" />
    <bpmn:sequenceFlow id="Flow_to_end_rejected" sourceRef="Task_ApplyRejection" targetRef="EndEvent_Rejected" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="document-approval">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="162" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SetPending_di" bpmnElement="Task_SetPending">
        <dc:Bounds x="240" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ReviewDocument_di" bpmnElement="Task_ReviewDocument">
        <dc:Bounds x="400" y="140" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Decision_di" bpmnElement="Gateway_Decision" isMarkerVisible="true">
        <dc:Bounds x="555" y="155" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="614.5" y="173" width="53" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ApplyRejection_di" bpmnElement="Task_ApplyRejection">
        <dc:Bounds x="670" y="230" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Rejected_di" bpmnElement="EndEvent_Rejected">
        <dc:Bounds x="832" y="252" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ApplyApproval_di" bpmnElement="Task_ApplyApproval">
        <dc:Bounds x="670" y="40" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Approved_di" bpmnElement="EndEvent_Approved">
        <dc:Bounds x="832" y="62" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="827" y="98" width="47" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_to_pending_di" bpmnElement="Flow_to_pending">
        <di:waypoint x="188" y="180" />
        <di:waypoint x="240" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_review_di" bpmnElement="Flow_to_review">
        <di:waypoint x="340" y="180" />
        <di:waypoint x="400" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_gateway_di" bpmnElement="Flow_to_gateway">
        <di:waypoint x="500" y="180" />
        <di:waypoint x="555" y="180" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_approved_di" bpmnElement="Flow_approved">
        <di:waypoint x="580" y="155" />
        <di:waypoint x="580" y="80" />
        <di:waypoint x="670" y="80" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="572" y="78" width="47" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_rejected_di" bpmnElement="Flow_rejected">
        <di:waypoint x="580" y="205" />
        <di:waypoint x="580" y="270" />
        <di:waypoint x="670" y="270" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_end_approved_di" bpmnElement="Flow_to_end_approved">
        <di:waypoint x="770" y="80" />
        <di:waypoint x="832" y="80" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_to_end_rejected_di" bpmnElement="Flow_to_end_rejected">
        <di:waypoint x="770" y="270" />
        <di:waypoint x="832" y="270" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
